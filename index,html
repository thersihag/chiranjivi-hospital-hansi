<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chiranjivi Hospital | Hansi - Advanced Medical Care</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root {
            --primary-blue: #0284c7; /* Trustworthy Medical Blue */
            --primary-dark: #0369a1;
            --accent-cyan: #06b6d4;
            --main-grey: #64748b;
            --bg-light: #f8fafc;
            --bg-medium: #f1f5f9;
            --white: #ffffff;
            --text-dark: #0f172a;
            --emergency-red: #e11d48;
            --card-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: linear-gradient(135deg, var(--bg-light) 0%, var(--bg-medium) 100%);
            color: var(--text-dark);
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        .container-main {
            max-width: 500px;
            margin: 0 auto;
            padding: 20px 15px;
        }

        /* Header Section */
        .header-section {
            text-align: center;
            padding: 30px 10px 15px;
        }

        .hospital-logo-box {
            width: 110px;
            height: 110px;
            background: var(--white);
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            box-shadow: var(--card-shadow);
            border: 4px solid var(--white);
            position: relative;
        }

        .hospital-logo-box i {
            font-size: 3.5rem;
            color: var(--primary-blue);
        }

        .hospital-name {
            font-weight: 800;
            font-size: 1.8rem;
            color: var(--text-dark);
            margin-bottom: 8px;
            letter-spacing: -0.5px;
        }

        .hospital-bio {
            font-size: 0.9rem;
            color: var(--primary-dark);
            font-weight: 700;
            line-height: 1.5;
            margin-bottom: 25px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Experience Badge */
        .experience-badge {
            background: var(--white);
            padding: 12px 20px;
            border-radius: 50px;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            box-shadow: var(--card-shadow);
            margin-bottom: 25px;
            border: 1px solid rgba(2, 132, 199, 0.1);
        }

        .exp-number {
            background: var(--primary-blue);
            color: white;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 0.9rem;
        }

        .exp-text {
            font-weight: 700;
            font-size: 0.85rem;
            color: var(--text-dark);
        }

        /* Quick Action Buttons */
        .action-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 30px;
        }

        .btn-action {
            padding: 18px;
            border-radius: 22px;
            text-decoration: none;
            text-align: center;
            font-weight: 700;
            font-size: 0.9rem;
            transition: var(--transition);
            box-shadow: var(--card-shadow);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            background: var(--white);
            border: 1px solid transparent;
            color: var(--text-dark);
        }

        .btn-call-main {
            background: var(--primary-blue);
            color: white;
            grid-column: span 2;
            flex-direction: row;
            justify-content: center;
            gap: 12px;
            font-size: 1.05rem;
        }

        .btn-call-main:hover {
            background: var(--primary-dark);
            color: white;
            transform: scale(1.02);
        }

        .btn-action:hover:not(.btn-call-main) {
            border-color: var(--primary-blue);
            color: var(--primary-blue);
            transform: translateY(-3px);
        }

        /* Service Sections Styling */
        .section-label {
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--main-grey);
            margin: 25px 0 15px 10px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-label::after {
            content: "";
            height: 1px;
            flex-grow: 1;
            background: rgba(0,0,0,0.08);
        }

        .service-category-card {
            background: var(--white);
            border-radius: 24px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: var(--card-shadow);
        }

        .category-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 1px dashed var(--bg-medium);
        }

        .category-icon {
            width: 40px;
            height: 40px;
            background: rgba(2, 132, 199, 0.1);
            color: var(--primary-blue);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
        }

        .category-title {
            font-weight: 800;
            font-size: 1rem;
            margin: 0;
            color: var(--text-dark);
        }

        .service-list {
            list-style: none;
            padding: 0;
            margin: 0;
            display: grid;
            grid-template-columns: 1fr;
            gap: 8px;
        }

        .service-item {
            font-size: 0.88rem;
            color: var(--main-grey);
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 500;
        }

        .service-item i {
            color: var(--accent-cyan);
            font-size: 0.8rem;
        }

        /* Timing Card */
        .timing-card {
            background: linear-gradient(135deg, #0f172a, #1e293b);
            color: white;
            border-radius: 24px;
            padding: 20px;
            margin-top: 25px;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        /* Map Section */
        .map-card {
            background: var(--white);
            padding: 12px;
            border-radius: 28px;
            box-shadow: var(--card-shadow);
            margin-top: 30px;
            overflow: hidden;
        }

        .map-iframe-container {
            border-radius: 20px;
            overflow: hidden;
            height: 220px;
            background: var(--bg-medium);
        }

        .address-box {
            padding: 15px 10px 5px;
            font-size: 0.85rem;
            color: var(--main-grey);
            display: flex;
            gap: 12px;
            line-height: 1.5;
        }

        /* Footer */
        .footer {
            text-align: center;
            padding: 40px 20px;
            margin-top: 40px;
            background: var(--white);
            border-radius: 40px 40px 0 0;
        }

        .footer-socials {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-bottom: 25px;
        }

        .social-btn {
            width: 45px;
            height: 45px;
            background: var(--bg-light);
            color: var(--primary-blue);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            text-decoration: none;
            transition: var(--transition);
        }

        .social-btn:hover {
            background: var(--primary-blue);
            color: white;
            transform: translateY(-5px);
        }

        .designer-tag {
            font-size: 0.7rem;
            color: var(--main-grey);
            margin-top: 15px;
            display: block;
            font-weight: 600;
        }

        /* Animations */
        .fade-in-up {
            animation: fadeInUp 0.8s ease-out forwards;
            opacity: 0;
        }

        @keyframes fadeInUp {
            from { transform: translateY(30px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .delay-1 { animation-delay: 0.2s; }
        .delay-2 { animation-delay: 0.4s; }
    </style>
</head>
